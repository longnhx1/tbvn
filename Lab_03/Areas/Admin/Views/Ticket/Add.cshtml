@model Lab_03.Models.Tour
@{
    ViewData["Title"] = "Thêm Tour Mới";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-tour-form.css" asp-append-version="true" />
}

<div class="ticket-form-page">
    <!-- Page Header -->
    <div class="ticket-form-header">
        <div class="ticket-form-header__left">
            <a asp-area="Admin" asp-controller="Tour" asp-action="Index" class="ticket-form-header__back">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="ticket-form-header__title">
                <h1>Thêm Tour Mới</h1>
                <p>Điền thông tin chi tiết để tạo tour mới</p>
            </div>
        </div>
        <div class="ticket-form-header__actions">
            <button type="button" class="btn-secondary" id="btnReset">
                <i class="fa-solid fa-rotate-left"></i>
                <span>Làm mới</span>
            </button>
            <button type="submit" form="productForm" class="btn-primary">
                <i class="fa-solid fa-plus"></i>
                <span>Lưu tour</span>
            </button>
        </div>
    </div>

    <!-- Form Container -->
    <form asp-area="Admin" asp-action="Add" method="post" enctype="multipart/form-data" id="productForm" class="ticket-form">
        <div class="ticket-form__grid">
            <!-- Left Column - Main Info -->
            <div class="ticket-form__main">
                <!-- Basic Information Card -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-box"></i>
                        <h2>Thông tin cơ bản</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-group">
                            <label asp-for="Name" class="form-label">
                                Tên tour <span class="required">*</span>
                            </label>
                            <input asp-for="Name" class="form-input" placeholder="Nhập tên tour..." />
                            <span asp-validation-for="Name" class="form-error"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Price" class="form-label">
                                    Giá cho 1 khách <span class="required">*</span>
                                </label>
                                <div class="input-with-suffix">
                                    <input asp-for="Price" type="number" class="form-input" placeholder="0" min="0" step="1000" />
                                    <span class="input-suffix">VNĐ</span>
                                </div>
                                <div class="form-hint" style="margin-top:0.35rem;">
                                    <i class="fa-solid fa-circle-info"></i>
                                    <span>Giá hiển thị cho một người lớn; trẻ em có thể áp dụng mức khác khi đặt.</span>
                                </div>
                                <span asp-validation-for="Price" class="form-error"></span>
                            </div>

                            <div class="form-group destination-picker">
                                <label asp-for="DestinationId" class="form-label">
                                    Điểm đến <span class="required">*</span>
                                </label>
                                <label for="destinationFilter" class="sr-only">Lọc điểm đến theo tên</label>
                                <input type="search"
                                       id="destinationFilter"
                                       class="form-input destination-picker__filter"
                                       placeholder="Gõ tên tỉnh, thành để lọc…"
                                       autocomplete="off" />
                                <div class="select-wrapper">
                                    <select asp-for="DestinationId" asp-items="ViewBag.Destinations" id="destinationSelect" class="form-select">
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-icon"></i>
                                </div>
                                <span asp-validation-for="DestinationId" class="form-error"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-calendar-days"></i>
                        <h2>Lịch trình &amp; chỗ</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="DepartureDate" class="form-label">Ngày khởi hành <span class="required">*</span></label>
                                <input asp-for="DepartureDate" class="form-input" type="date" />
                                <span asp-validation-for="DepartureDate" class="form-error"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="DurationDays" class="form-label">Số ngày <span class="required">*</span></label>
                                <input asp-for="DurationDays" type="number" class="form-input" min="1" max="30" />
                                <span asp-validation-for="DurationDays" class="form-error"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="DepartureLocation" class="form-label">Điểm khởi hành <span class="required">*</span></label>
                            <input asp-for="DepartureLocation" class="form-input" placeholder="VD: TP. Hồ Chí Minh" />
                            <span asp-validation-for="DepartureLocation" class="form-error"></span>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="MaxGuests" class="form-label">Số khách tối đa</label>
                                <input asp-for="MaxGuests" type="number" class="form-input" min="1" max="200" />
                            </div>
                            <div class="form-group">
                                <label asp-for="AvailableSeats" class="form-label">Còn trống</label>
                                <input asp-for="AvailableSeats" type="number" class="form-input" min="0" max="200" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="TransportType" class="form-label">Phương tiện</label>
                            <input asp-for="TransportType" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label asp-for="IncludedServices" class="form-label">Trong giá</label>
                            <textarea asp-for="IncludedServices" class="form-textarea" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label asp-for="ExcludedServices" class="form-label">Không gồm</label>
                            <textarea asp-for="ExcludedServices" class="form-textarea" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label asp-for="CancellationPolicy" class="form-label">Chính sách hủy</label>
                            <textarea asp-for="CancellationPolicy" class="form-textarea" rows="2"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Description Card -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-align-left"></i>
                        <h2>Mô tả tour</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Mô tả tour</label>
                            <textarea asp-for="Description" class="form-textarea" rows="6" placeholder="Nhập mô tả tour..."></textarea>
                            <span asp-validation-for="Description" class="form-error"></span>
                            <div class="form-hint">
                                <i class="fa-solid fa-circle-info"></i>
                                <span>Mô tả giúp khách hàng hiểu rõ hơn về tour</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Image Upload -->
            <div class="ticket-form__sidebar">
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-image"></i>
                        <h2>Ảnh đại diện &amp; album</h2>
                    </div>
                    <div class="form-card__body">
                        <p class="form-hint" style="margin-bottom:0.75rem;">Ảnh chính hiển thị trên thẻ tour; ảnh phụ dùng cho trang chi tiết.</p>
                        <div class="image-upload" id="imageUpload">
                            <input type="file" name="imageUrl" id="imageInput" class="image-upload__input" accept="image/*" />

                            <!-- Upload placeholder -->
                            <div class="image-upload__placeholder" id="uploadPlaceholder">
                                <div class="image-upload__icon">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                </div>
                                <p class="image-upload__text">Kéo thả ảnh vào đây hoặc</p>
                                <label for="imageInput" class="image-upload__btn">
                                    <i class="fa-solid fa-folder-open"></i>
                                    <span>Chọn ảnh</span>
                                </label>
                                <p class="image-upload__hint">PNG, JPG, WEBP (tối đa 5MB)</p>
                            </div>

                            <!-- Image preview -->
                            <div class="image-upload__preview d-none" id="imagePreviewContainer">
                                <img id="imagePreview" src="#" alt="Ảnh xem trước" />
                                <div class="image-upload__overlay">
                                    <button type="button" class="image-upload__remove" id="removeImage">
                                        <i class="fa-solid fa-trash"></i>
                                        <span>Xóa ảnh</span>
                                    </button>
                                    <label for="imageInput" class="image-upload__change">
                                        <i class="fa-solid fa-arrows-rotate"></i>
                                        <span>Đổi ảnh</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="form-group" style="margin-top:1rem;">
                            <label class="form-label">Ảnh phụ (chọn nhiều)</label>
                            <input type="file" name="galleryImages" class="form-input" accept="image/*" multiple />
                        </div>
                    </div>
                </div>

                <!-- Tips Card -->
                <div class="form-card form-card--tips">
                    <div class="form-card__header">
                        <i class="fa-solid fa-lightbulb"></i>
                        <h2>Mẹo hay</h2>
                    </div>
                    <div class="form-card__body">
                        <ul class="tips-list">
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Sử dụng ảnh có độ phân giải cao</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Đặt tên tour rõ ràng, dễ tìm kiếm</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Mô tả đầy đủ thông số kỹ thuật</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Chọn đúng điểm đến để dễ quản lý</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-tour-form.js" asp-append-version="true"></script>
    <script src="~/js/destination-select-filter.js" asp-append-version="true"></script>
}
