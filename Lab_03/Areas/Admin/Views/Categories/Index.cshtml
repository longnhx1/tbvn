@model IEnumerable<Lab_03.Models.Destination>

@{
    ViewData["Title"] = "Destination Management";
}

<link rel="stylesheet" href="~/css/admin-destinations.css">
<script src="~/js/admin-destinations.js" defer></script>

<div class="category-container">
    <!-- Header Section -->
    <div class="category-header">
        <div class="header-content">
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn-back-dashboard">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M10 16L4 10M4 10L10 4M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Dashboard
            </a>
            <h1 class="category-title">Điểm đến</h1>
            <p class="category-subtitle">Quản lý điểm đến của tour</p>
        </div>
            <a asp-action="Add" class="btn-add-category">
            <svg class="icon-plus" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            Add Destination
        </a>
    </div>

    <!-- Search & Filter Bar -->
    <div class="search-bar">
        <svg class="icon-search" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
            <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <input type="text"
               class="search-input"
               id="searchInput"
               placeholder="Search categories...">
    </div>

    <!-- Categories Table -->
    <div class="categories-table">
        @if (Model.Any())
        {
            <div class="table-header">
                <div class="col-name">Destination Name</div>
                <div class="col-actions">Actions</div>
            </div>

            @foreach (var destination in Model)
            {
                <div class="table-row" data-category-name="@destination.Name.ToLower()">
                    <div class="col-name">
                        <span class="category-name-text">@destination.Name</span>
                    </div>
                    <div class="col-actions">
                        <a asp-action="Update" asp-route-id="@destination.Id" class="action-btn edit-btn">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                <path d="M2 14H14M11 2L14 5M1 15L3.5 14.5L12 6L9 3L1 11V15Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Edit
                        </a>
                        <button class="action-btn delete-btn" data-id="@destination.Id" data-name="@destination.Name">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                <path d="M2 4H14M3.5 4V13C3.5 13.5 4 14 4.5 14H11.5C12 14 12.5 13.5 12.5 13V4M6 4V12M10 4V12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Delete
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <svg class="empty-icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2" />
                    <path d="M24 16V24M24 32H24.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <p class="empty-text">No destinations found</p>
                <a asp-action="Add" class="btn-add-empty">Create your first destination</a>
            </div>
        }
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-content">
        <h3>Delete Destination</h3>
        <p id="deleteMessage">Are you sure you want to delete this destination?</p>
        <div class="modal-actions">
            <button class="btn-cancel" id="cancelDelete">Cancel</button>
            <form id="deleteForm" method="post" asp-action="Delete" style="display: inline;">
                <input type="hidden" name="id" id="deleteId">
                <button type="submit" class="btn-confirm-delete">Delete</button>
            </form>
        </div>
    </div>
</div>
