@using Lab_03.Models
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Travel Booking Việt Nam – đặt tour trong nước, lịch trình rõ ràng, giá minh bạch." />
    <title>@ViewData["Title"] – Travel Booking Việt Nam</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;0,800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/customer-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tours-bookings.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="navbar" id="mainNavbar">
        <div class="navbar__inner">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="navbar__logo" aria-label="Trang chủ Travel Booking">
                <img src="/images/logo.png" alt="" width="36" height="36" />
                <span class="navbar__logo-text">
                    <strong>Travel Booking</strong>
                    <span>Việt Nam</span>
                </span>
            </a>

            <nav class="navbar__menu" aria-label="Menu chính">
                <ul class="navbar__menu-list">
                    <li><a asp-area="" asp-controller="Home" asp-action="Index" class="navbar__menu-link">Trang chủ</a></li>
                    <li><a asp-area="" asp-controller="Tours" asp-action="Index" class="navbar__menu-link">Tour</a></li>
                    <li><a asp-area="" asp-controller="Bookings" asp-action="MyOrders" class="navbar__menu-link">Lịch sử đặt tour</a></li>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole(SD.Role_Admin))
                    {
                        <li><a asp-area="Admin" asp-controller="Home" asp-action="Index" class="navbar__menu-link">Quản trị</a></li>
                    }
                </ul>
            </nav>

            <div class="navbar__actions">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer__inner">
            <div class="footer__col">
                <h3 class="footer__heading">Travel Booking Việt Nam</h3>
                <p class="footer__text">Nền tảng đặt tour nội địa: chọn lịch, xem giá, giữ chỗ nhanh chóng.</p>
            </div>
            <div class="footer__col">
                <h3 class="footer__heading">Hỗ trợ</h3>
                <ul class="footer__links">
                    <li><a asp-area="" asp-controller="Tours" asp-action="Index">Danh sách tour</a></li>
                    <li><a asp-area="" asp-controller="Bookings" asp-action="MyOrders">Tour đã đặt</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách &amp; quyền riêng tư</a></li>
                </ul>
            </div>
            <div class="footer__col">
                <h3 class="footer__heading">Liên hệ</h3>
                <ul class="footer__contact">
                    <li><i class="fa-solid fa-phone" aria-hidden="true"></i> <a href="tel:19001234">1900 1234</a></li>
                    <li><i class="fa-solid fa-envelope" aria-hidden="true"></i> <a href="mailto:support@travelbooking.vn">support@travelbooking.vn</a></li>
                </ul>
            </div>
        </div>
        <div class="footer__bottom">
            <p>© @DateTime.Now.Year Travel Booking Việt Nam</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
